<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!-- Fix translate error -->
    <preference for="Magento\Translation\Model\ResourceModel\Translate"
                type="Tigren\Pwa\Override\Magento\Translation\Model\ResourceModel\Translate" />

    <!-- Add custom scripts to header of pwa app -->
    <type name="Magento\UpwardConnector\Controller\Upward">
        <plugin name="apply_gtm" type="Tigren\Pwa\Plugin\Magento\UpwardConnector\Controller\Upward" />
    </type>

    <!-- Check upward configurations to determine regular theme or pwa theme -->
    <type name="Magento\Framework\App\AreaList">
        <plugin name="Tigren\Pwa\Plugin\Magento\Framework\App\AreaList"
                type="Tigren\Pwa\Plugin\Magento\Framework\App\AreaList" sortOrder="20" />
    </type>

    <virtualType name="Magento\Framework\GraphQlSchemaStitching\Reader" type="Magento\Framework\GraphQlSchemaStitching\Common\Reader">
        <arguments>
            <argument name="readers" xsi:type="array">
                <item name="productFilterEntityIdReader" xsi:type="object">Tigren\Pwa\Model\Config\FilterEntityIdReader</item>
            </argument>
        </arguments>
    </virtualType>

    <type name="Magento\Framework\Console\CommandListInterface">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="tigren_pwa_command_collect_pwa_translations" xsi:type="object">Tigren\Pwa\Console\Command\CollectPhrases</item>
            </argument>
        </arguments>
    </type>

    <!-- Improve the first graphql request after flushing caches -->
    <type name="Magento\Framework\App\Cache\Manager">
        <plugin name="Tigren\Pwa\Plugin\Magento\Framework\App\Cache\Manager"
                type="Tigren\Pwa\Plugin\Magento\Framework\App\Cache\Manager"
        />
    </type>
    <type name="Magento\Backend\Controller\Adminhtml\Cache\FlushAll">
        <plugin name="Tigren\Pwa\Plugin\Magento\Backend\Controller\Adminhtml\Cache\FlushAll"
                type="Tigren\Pwa\Plugin\Magento\Backend\Controller\Adminhtml\Cache\FlushAll"
        />
    </type>
    <type name="Magento\Backend\Controller\Adminhtml\Cache\FlushSystem">
        <plugin name="Tigren\Pwa\Plugin\Magento\Backend\Controller\Adminhtml\Cache\FlushSystem"
                type="Tigren\Pwa\Plugin\Magento\Backend\Controller\Adminhtml\Cache\FlushSystem"
        />
    </type>
    <type name="Magento\Backend\Controller\Adminhtml\Cache\MassRefresh">
        <plugin name="Tigren\Pwa\Plugin\Magento\Backend\Controller\Adminhtml\Cache\MassRefresh"
                type="Tigren\Pwa\Plugin\Magento\Backend\Controller\Adminhtml\Cache\MassRefresh"
        />
    </type>
    <type name="Tigren\Pwa\Helper\Data">
        <arguments>
            <argument name="reader" xsi:type="object">Magento\Framework\GraphQlSchemaStitching\Reader</argument>
            <argument name="cacheId" xsi:type="string">Magento_Framework_GraphQlSchemaStitching_Config_Data</argument>
        </arguments>
    </type>
    <type name="Magento\Framework\GraphQl\Schema\Type\Entity\DefaultMapper">
        <arguments>
            <argument name="map" xsi:type="array">
                <item name="catalog_product" xsi:type="array">
                    <item name="product" xsi:type="string">ProductInterface</item>
                    <item name="simple" xsi:type="string">SimpleProduct</item>
                    <item name="virtual" xsi:type="string">VirtualProduct</item>
                </item>
                <item name="customizable_options" xsi:type="array">
                    <item name="field" xsi:type="string">CustomizableFieldOption</item>
                    <item name="date" xsi:type="string">CustomizableDateOption</item>
                    <item name="date_time" xsi:type="string">CustomizableDateOption</item>
                    <item name="time" xsi:type="string">CustomizableDateOption</item>
                    <item name="file" xsi:type="string">CustomizableFileOption</item>
                    <item name="area" xsi:type="string">CustomizableAreaOption</item>
                    <item name="drop_down" xsi:type="string">CustomizableDropDownOption</item>
                    <item name="multiple" xsi:type="string">CustomizableMultipleOption</item>
                    <item name="radio" xsi:type="string">CustomizableRadioOption</item>
                    <item name="checkbox" xsi:type="string">CustomizableCheckboxOption</item>
                </item>
                <item name="sort_attributes" xsi:type="array">
                    <item name="product_sort_attributes" xsi:type="string">ProductAttributeSortInput</item>
                </item>
                <item name="filter_attributes" xsi:type="array">
                    <item name="product_filter_attributes" xsi:type="string">ProductAttributeFilterInput</item>
                </item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\Framework\GraphQl\Schema\Type\Entity\DefaultMapper">
        <arguments>
            <argument name="map" xsi:type="array">
                <item name="catalog_product" xsi:type="array">
                    <item name="downloadable" xsi:type="string">DownloadableProduct</item>
                </item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\Framework\GraphQl\Schema\Type\Entity\DefaultMapper">
        <arguments>
            <argument name="map" xsi:type="array">
                <item name="catalog_product" xsi:type="array">
                    <item name="giftcard" xsi:type="string">GiftCardProduct</item>
                </item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\Framework\GraphQl\Schema\Type\Entity\DefaultMapper">
        <arguments>
            <argument name="map" xsi:type="array">
                <item name="catalog_product" xsi:type="array">
                    <item name="configurable" xsi:type="string">ConfigurableProduct</item>
                </item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\Framework\GraphQl\Schema\Type\Entity\DefaultMapper">
        <arguments>
            <argument name="map" xsi:type="array">
                <item name="catalog_product" xsi:type="array">
                    <item name="bundle" xsi:type="string">BundleProduct</item>
                </item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\Framework\GraphQl\Schema\Type\Entity\DefaultMapper">
        <arguments>
            <argument name="map" xsi:type="array">
                <item name="catalog_product" xsi:type="array">
                    <item name="downloadable" xsi:type="string">DownloadableProduct</item>
                </item>
            </argument>
        </arguments>
    </type>

    <!-- Add category thumbnail attribute -->
    <type name="Tigren\Pwa\Controller\Adminhtml\Category\Thumbnail\Upload">
        <arguments>
            <argument name="imageUploader" xsi:type="object">Magento\Catalog\CategoryImageUpload</argument>
        </arguments>
    </type>

    <type name="Magento\Framework\DB\Adapter\SqlVersionProvider">
        <arguments>
            <argument name="supportedVersionPatterns" xsi:type="array">
                <item name="MySQL-8" xsi:type="string">^8\.0\.</item>
                <item name="MySQL-5.7" xsi:type="string">^5\.7\.</item>
                <item name="MariaDB-(10.2-10.9)" xsi:type="string">^10\.[2-9]\.</item>
            </argument>
        </arguments>
    </type>

    <!-- Fixed cannot apply discount for virtual cart-->
    <type name="Magento\QuoteGraphQl\Model\Resolver\Discounts">
        <plugin name="Tigren\Pwa\Plugin\Magento\QuoteGraphQl\Model\Resolver\Discounts"
                type="Tigren\Pwa\Plugin\Magento\QuoteGraphQl\Model\Resolver\Discounts"
        />
    </type>
    <type name="Magento\CatalogGraphQl\DataProvider\Product\LayeredNavigation\LayerBuilder">
        <plugin name="Tigren\Pwa\Plugin\Magento\CatalogGraphQl\DataProvider\Product\LayeredNavigation\LayerBuilder"
                type="Tigren\Pwa\Plugin\Magento\CatalogGraphQl\DataProvider\Product\LayeredNavigation\LayerBuilder" />
    </type>

    <!-- Fix error system params null currency -->
    <type name="Magento\Directory\Model\Currency">
        <plugin name="Tigren\Pwa\Plugin\Magento\Directory\Model\Currency"
                type="Tigren\Pwa\Plugin\Magento\Directory\Model\Currency"
        />
    </type>
</config>
